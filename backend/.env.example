# ── Option A: Direct SAP Connection (Basic Auth) ──────────────────────────────
# Simplest approach — backend calls SAP OData directly.
# Requires the server running this backend to have network access to SAP host.
# Get these values from your BASIS team.
SAP_BASE_URL=https://<sap-host>:<port>
SAP_CLIENT=100
SAP_USER=<sap-service-account-username>
SAP_PASSWORD=<sap-service-account-password>
SAP_ODATA_SERVICE=/sap/opu/odata/sap/CNVLTVF3_SRV

# ── Option C: SharePoint Scheduled Export ─────────────────────────────────────
# SAP exports ltvf_latest.xlsx to SharePoint daily (overnight background job).
# Dashboard reads the file via Microsoft Graph API — no BTP or Cloud Connector needed.
#
# Setup steps:
#   1. Create a SharePoint folder for SAP exports
#   2. Register an Azure App in portal.azure.com → Azure Active Directory → App Registrations
#      → Add API Permission: Microsoft Graph → Application → Files.Read.All
#      → Grant admin consent
#   3. Fill in the values below from the Azure App registration

SHAREPOINT_TENANT_ID=<azure-directory-tenant-id>
SHAREPOINT_CLIENT_ID=<azure-app-client-id>
SHAREPOINT_CLIENT_SECRET=<azure-app-client-secret>
SHAREPOINT_SITE_NAME=<sharepoint-site-name>
SHAREPOINT_FOLDER_PATH=/SAP Exports
SHAREPOINT_FILENAME=ltvf_latest.xlsx
# BTP Global Account:  79b39184-de86-4342-8a71-7d4b98c7712f  (DMLT BTP Global Account - Canary)
# BTP Subaccount:      85de1f19-b01f-4eb6-b07b-8037a9d9431a
# Environment:         Canary (canary.cockpit.btp.int.sap)
#
# Step 1 — Create a Destination Service instance in BTP subaccount
#          Service Marketplace → Destination → New Instance → plan: lite
#          Download the service key and copy client_id, client_secret, uri below.
#
# Step 2 — Create a Connectivity Service instance (needed for on-premise proxy)
#          Service Marketplace → Connectivity → New Instance → plan: lite
#          Download service key and copy onpremise_proxy_host, onpremise_proxy_port.
#
# Step 3 — Create a named Destination in BTP cockpit:
#          Connectivity → Destinations → New Destination
#          Name: LTVF_ONPREMISE
#          Type: HTTP, URL: http://<sap-host>:<port>
#          Proxy Type: OnPremise, Authentication: BasicAuthentication
#          User/Password: <sap-service-account>

# XSUAA token endpoint (from Destination Service key → "url" + "/oauth/token")
BTP_TOKEN_URL=https://<subaccount-subdomain>.authentication.sap.hana.ondemand.com/oauth/token

# Destination Service credentials (from service key)
BTP_DEST_CLIENT_ID=<destination-service-clientid>
BTP_DEST_CLIENT_SECRET=<destination-service-clientsecret>
BTP_DEST_SVC_URL=https://destination-configuration.cfapps.sap.hana.ondemand.com

# Connectivity Service proxy (from service key → onpremise_proxy_host / onpremise_proxy_port)
BTP_CONN_PROXY_HOST=connectivity.cf.sap.hana.ondemand.com
BTP_CONN_PROXY_PORT=20003

# Name of the BTP Destination pointing to on-premise SAP
SAP_DESTINATION_NAME=LTVF_ONPREMISE
